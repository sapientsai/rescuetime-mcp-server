{
  "name": "rescuetime-mcp-server",
  "version": "0.1.0",
  "description": "A Model Context Protocol (MCP) server for RescueTime - access productivity data, focus sessions, highlights, and activity tracking.",
  "keywords": [
    "mcp",
    "rescuetime",
    "productivity",
    "api",
    "model-context-protocol",
    "claude",
    "ai-assistant",
    "fastmcp",
    "focus",
    "time-tracking"
  ],
  "author": "Jordan Burke <jordan.burke@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jordanburke/rescuetime-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/rescuetime-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/jordanburke/rescuetime-mcp-server/issues"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector dist/index.js",
    "start": "pnpm build && npx rescuetime-mcp-server",
    "serve": "pnpm build && node dist/index.js"
  },
  "bin": {
    "rescuetime-mcp-server": "dist/bin.js"
  },
  "mcpName": "io.github.jordanburke/rescuetime-mcp-server",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "prettier": "ts-builds/prettier",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "dotenv": "^17.3.1",
    "fastmcp": "^3.34.0",
    "functype": "^0.51.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "ts-builds": "^2.6.2",
    "tsdown": "^0.21.5"
  }
}
